# Your Pixmax platform key (create one in the Pixmax console). Required.
PIXMAX_API_KEY=pk_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: credit → USD rate used ONLY for cost display in tool output.
# Depends on your plan: Starter 0.010, Pro 0.007, Ultra/Max 0.0065, annual 0.005.
# The API always bills in credits regardless of this value.
PIXMAX_CREDIT_USD=0.007

# Optional: reuse a specific Pixmax project instead of auto-creating one.
# PIXMAX_PROJECT_UUID=

# Optional: override the API base URL.
# PIXMAX_BASE_URL=https://console.pixmax.ai/openapi
